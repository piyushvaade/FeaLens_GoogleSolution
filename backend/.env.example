# FeaLens Backend Environment Variables Template
# Copy this file to .env and replace the values with your actual keys.
# NEVER commit your actual .env file to GitHub.

# API Keys for Mistral AI reasoning agents
MISTRAL_API_KEY="your_mistral_api_key_here"

# Supabase configuration for Dataset storage and retrieval (Optional for demo)
SUPABASE_URL="your_supabase_url_here"
SUPABASE_KEY="your_supabase_anon_key_here"
